{
  "name": "sure-walk",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "dev:mobile": "pnpm --filter surewalk-mobile-app start",
    "build:mobile": "pnpm --filter surewalk-mobile-app build",
    "build:web": "pnpm --filter surewalk-web-app build",
    "lint:mobile": "pnpm --filter surewalk-mobile-app lint",
    "lint:web": "pnpm --filter surewalk-web-app lint",
    "lint": "pnpm lint:mobile && pnpm lint:web",
    "format": "prettier --write .",
    "format:check-mobile": "prettier apps/mobile --check --ignore-unknown",
    "format:check-web": "prettier apps/web --check --ignore-unknown",
    "format:check": "pnpm format:check-mobile && pnpm format:check-web"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "libs/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.1"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
